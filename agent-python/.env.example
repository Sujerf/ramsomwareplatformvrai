# ── Connexion au serveur SOC ──────────────────────────────────────────────────
# IP ou hostname du serveur RansomShield (PAS 127.0.0.1 sur une VM distante)
RANSHIELD_API_URL=http://10.15.55.88:8000/api

# Secret partagé avec le backend (copier la valeur de RANSHIELD_API_SECRET du .env Laravel)
RANSHIELD_API_SECRET=

# ── Identité de cet agent ────────────────────────────────────────────────────
# Nom lisible affiché dans la console SOC
RANSHIELD_AGENT_NAME=agent-vm-01

# Rôle de la machine : client | file_server | soc_server | attacker_demo | unknown
RANSHIELD_HOST_ROLE=client

# ── Surveillance ─────────────────────────────────────────────────────────────
RANSHIELD_MONITOR_MODE=host
RANSHIELD_HEARTBEAT_INTERVAL=30
RANSHIELD_SCAN_INTERVAL=5

RANSHIELD_ENABLE_FILE_MONITOR=true
RANSHIELD_ENABLE_PROCESS_MONITOR=true
RANSHIELD_ENABLE_NETWORK_CONTEXT=true

# Chemins à surveiller (séparés par des virgules)
RANSHIELD_MONITOR_PATHS=/home,/tmp,/media,/mnt

# Chemins à ignorer
RANSHIELD_EXCLUDED_PATHS=/proc,/sys,/dev,/run,/snap,/var/lib,node_modules,vendor,.git,venv,__pycache__
